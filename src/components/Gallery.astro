---
// src/components/Gallery.astro
import { Image, getImage, type LocalImageProps } from 'astro:assets';
import 'glightbox/dist/css/glightbox.min.css';

type ImportedImage = Exclude<LocalImageProps['src'], Promise<unknown>>;

interface GalleryImage {
  src: ImportedImage;
  thumbnail?: ImportedImage;
  alt: string;
  title?: string;
  fit?: 'cover' | 'contain';
}

const { images = [] } = Astro.props as { images?: GalleryImage[] };
const galleryId = `gallery-${crypto.randomUUID()}`;

const galleryImages = await Promise.all(images.map(async (img) => {
  const lightbox = await getImage({
    src: img.src,
    width: 1800,
    format: 'webp',
    quality: 82,
  });

  return {
    ...img,
    lightboxSrc: lightbox.src,
  };
}));
---

<style>
.gallery {
  border: 1px solid var(--color-accent);
  box-sizing: border-box;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
  margin-top: 1.5rem;
  padding: 1rem;
}
.gallery a {
  aspect-ratio: 4 / 3;
  overflow: hidden;
  border-radius: var(--radius-medium);
}
.gallery img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.2s ease;
  cursor: zoom-in;
}
.gallery img.fit-contain {
  background: var(--primitive-black);
  object-fit: contain;
}
.gallery img:hover {
  transform: scale(1.02);
}

:global([data-theme='dark'] .glightbox-clean .gslide-description) {
  background: var(--primitive-black);
}

:global([data-theme='dark'] .glightbox-clean .gslide-title),
:global([data-theme='dark'] .glightbox-clean .gslide-desc) {
  color: var(--primitive-white);
}
</style>

<script>
  type GalleryLightbox = {
    destroy: () => void;
    openAt: (index?: number) => void;
  };

  type GalleryLightboxFactory = (options: Record<string, unknown>) => GalleryLightbox;

  type GalleryState = {
    mysterylandGalleryLightboxes?: Map<string, GalleryLightbox>;
    mysterylandGalleryLightboxImport?: Promise<GalleryLightboxFactory>;
    mysterylandGalleryClickBound?: boolean;
  };

  const galleryState = () => globalThis as typeof globalThis & GalleryState;

  const loadGLightbox = () => {
    const state = galleryState();
    state.mysterylandGalleryLightboxImport ??= import('glightbox').then((module) => module.default as GalleryLightboxFactory);
    return state.mysterylandGalleryLightboxImport;
  };

  const initGalleryLightbox = async () => {
    const state = galleryState();
    const GLightbox = await loadGLightbox();

    state.mysterylandGalleryLightboxes ??= new Map();

    document.querySelectorAll<HTMLElement>('[data-gallery-id]').forEach((gallery) => {
      const galleryId = gallery.dataset.galleryId;
      if (!galleryId) return;

      state.mysterylandGalleryLightboxes?.get(galleryId)?.destroy();

      const lightbox = GLightbox({
        selector: `[data-gallery-id="${galleryId}"] .glightbox`,
        touchNavigation: true,
        loop: true,
        zoomable: true,
        openEffect: 'zoom',
        closeEffect: 'fade',
        slideEffect: 'slide',
      }) as GalleryLightbox;

      state.mysterylandGalleryLightboxes?.set(galleryId, lightbox);
    });
  };

  const scheduleGalleryLightboxInit = () => {
    void initGalleryLightbox();
    requestAnimationFrame(() => void initGalleryLightbox());
    setTimeout(() => void initGalleryLightbox(), 100);
  };

  const bindGalleryLightboxClick = () => {
    const state = galleryState();
    if (state.mysterylandGalleryClickBound) return;
    state.mysterylandGalleryClickBound = true;

    document.addEventListener('click', async (event) => {
      const target = event.target instanceof Element
        ? event.target.closest<HTMLAnchorElement>('a.glightbox')
        : null;
      if (!target) return;

      const gallery = target.closest<HTMLElement>('[data-gallery-id]');
      const galleryId = gallery?.dataset.galleryId;
      if (!galleryId) return;

      event.preventDefault();
      event.stopPropagation();

      try {
        await initGalleryLightbox();
        const index = Number(target.dataset.index || '0');
        galleryState().mysterylandGalleryLightboxes?.get(galleryId)?.openAt(index);
      } catch (error) {
        console.error('Failed to open gallery lightbox', error);
      }
    }, { capture: true });
  };

  const bootGalleryLightbox = () => {
    bindGalleryLightboxClick();
    scheduleGalleryLightboxInit();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootGalleryLightbox, { once: true });
  } else {
    bootGalleryLightbox();
  }

  document.addEventListener('astro:page-load', bootGalleryLightbox);
</script>

<div class="gallery" data-gallery-id={galleryId}>
  {galleryImages.map((img, index) => (
    <a href={img.lightboxSrc} class="glightbox" data-gallery={galleryId} data-type="image" data-title={img.title || img.alt} data-index={index}>
      <Image
        src={img.thumbnail || img.src}
        alt={img.alt}
        class:list={[`fit-${img.fit || 'cover'}`]}
        widths={[300, 600, 900]}
        sizes="(max-width: 600px) 100vw, 600px"
        format="webp"
        quality={78}
      />
    </a>
  ))}
</div>
