---
// src/components/Gallery.astro
import { Image, getImage, type LocalImageProps } from 'astro:assets';
import 'glightbox/dist/css/glightbox.min.css';
import GalleryLightboxIsland from './GalleryLightboxIsland';

type ImportedImage = Exclude<LocalImageProps['src'], Promise<unknown>>;

interface GalleryImage {
  src: ImportedImage;
  thumbnail?: ImportedImage;
  alt: string;
  title?: string;
  fit?: 'cover' | 'contain';
}

const { images = [] } = Astro.props as { images?: GalleryImage[] };
const galleryId = `gallery-${crypto.randomUUID()}`;

const galleryImages = await Promise.all(images.map(async (img) => {
  const lightbox = await getImage({
    src: img.src,
    width: 1800,
    format: 'webp',
    quality: 82,
  });

  return {
    ...img,
    lightboxSrc: lightbox.src,
  };
}));
---

<style>
.gallery {
  border: 1px solid var(--color-accent);
  box-sizing: border-box;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
  margin-top: 1.5rem;
  padding: 1rem;
}
.gallery a {
  aspect-ratio: 4 / 3;
  overflow: hidden;
  border-radius: var(--radius-medium);
}
.gallery img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.2s ease;
  cursor: zoom-in;
}
.gallery img.fit-contain {
  background: var(--primitive-black);
  object-fit: contain;
}
.gallery img:hover {
  transform: scale(1.02);
}

:global([data-theme='dark'] .glightbox-clean .gslide-description) {
  background: var(--primitive-black);
}

:global([data-theme='dark'] .glightbox-clean .gslide-title),
:global([data-theme='dark'] .glightbox-clean .gslide-desc) {
  color: var(--primitive-white);
}
</style>

<div id={galleryId} class="gallery" data-gallery-id={galleryId}>
  {galleryImages.map((img, index) => (
    <a href={img.lightboxSrc} class="glightbox" data-gallery={galleryId} data-type="image" data-title={img.title || img.alt} data-index={index}>
      <Image
        src={img.thumbnail || img.src}
        alt={img.alt}
        class:list={[`fit-${img.fit || 'cover'}`]}
        widths={[300, 600, 900]}
        sizes="(max-width: 600px) 100vw, 600px"
        format="webp"
        quality={78}
      />
    </a>
  ))}
  <GalleryLightboxIsland galleryId={galleryId} client:only="preact" />
</div>
