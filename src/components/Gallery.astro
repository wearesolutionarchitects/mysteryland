---
// src/components/Gallery.astro
import { Image, type LocalImageProps } from 'astro:assets';
import 'glightbox/dist/css/glightbox.min.css';

type ImportedImage = Exclude<LocalImageProps['src'], Promise<unknown>>;

interface GalleryImage {
  src: ImportedImage;
  thumbnail?: ImportedImage;
  alt: string;
  title?: string;
}

const { images = [] } = Astro.props as { images?: GalleryImage[] };
---

<style>
.gallery {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1rem;
  margin-top: 1.5rem;
}
.gallery a {
  aspect-ratio: 4 / 3;
  overflow: hidden;
  border-radius: 0.5rem;
}
.gallery img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.2s ease;
  cursor: zoom-in;
}
.gallery img:hover {
  transform: scale(1.02);
}

:global([data-theme='dark'] .glightbox-clean .gslide-description) {
  background: #000;
}

:global([data-theme='dark'] .glightbox-clean .gslide-title),
:global([data-theme='dark'] .glightbox-clean .gslide-desc) {
  color: #fff;
}
</style>

<script>
  import GLightbox from 'glightbox';

  GLightbox({
    selector: '.glightbox',
    touchNavigation: true,
    loop: true,
    zoomable: true,
    openEffect: 'zoom',
    closeEffect: 'fade',
    slideEffect: 'slide'
  });
</script>

<div class="gallery">
  {images.map((img) => (
    <a href={img.src.src} class="glightbox" data-gallery="gallery" data-title={img.title || img.alt}>
      <Image
        src={img.thumbnail || img.src}
        alt={img.alt}
        widths={[300, 600, 900]}
        sizes="(max-width: 600px) 100vw, 600px"
      />
    </a>
  ))}
</div>
