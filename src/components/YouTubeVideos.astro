---
interface YouTubeVideo {
  id: string;
  title: string;
}

interface Props {
  videos: YouTubeVideo[];
}

const { videos } = Astro.props;
const videoIdPattern = /^[A-Za-z0-9_-]{11}$/;

for (const video of videos) {
  if (!videoIdPattern.test(video.id)) {
    throw new Error(`Ungültige YouTube-Video-ID: ${video.id}`);
  }
}
---

<div class="youtube-videos">
  {videos.map(({ id, title }) => (
    <figure>
      <div class="video-frame">
        <button class="video-consent" type="button" data-video-id={id} data-video-title={title}>
          <img
            src={`https://i.ytimg.com/vi/${id}/hqdefault.jpg`}
            alt=""
            loading="lazy"
            decoding="async"
          />
          <span class="video-overlay">
            <span class="play-icon" aria-hidden="true">▶</span>
            <span>Video laden</span>
          </span>
        </button>
        <noscript>
          <a href={`https://www.youtube-nocookie.com/embed/${id}`}>Video auf YouTube öffnen</a>
        </noscript>
      </div>
      <figcaption>{title}</figcaption>
    </figure>
  ))}
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.video-consent').forEach((button) => {
    button.addEventListener('click', () => {
      const videoId = button.dataset.videoId;
      const videoTitle = button.dataset.videoTitle || 'YouTube-Video';
      const frame = button.closest('.video-frame');

      if (!videoId || !frame) return;

      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1`;
      iframe.title = videoTitle;
      iframe.loading = 'lazy';
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.allowFullscreen = true;

      frame.replaceChildren(iframe);
    });
  });
</script>

<style>
  .youtube-videos {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
    gap: 1.5rem;
    margin-block: 1.5rem;
  }

  figure {
    min-width: 0;
    margin: 0;
  }

  .video-frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: #000;
  }

  iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-consent {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    padding: 0;
    color: var(--sl-color-white);
    background: #000;
    font: inherit;
    font-weight: 700;
    cursor: pointer;
  }

  .video-consent img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.78;
    transition: opacity 160ms ease, transform 160ms ease;
  }

  .video-consent:hover,
  .video-consent:focus-visible {
    outline: 2px solid var(--sl-color-accent-high);
    outline-offset: -2px;
  }

  .video-consent:hover img,
  .video-consent:focus-visible img {
    opacity: 0.92;
    transform: scale(1.02);
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
    background: linear-gradient(to bottom, transparent, rgba(0, 0, 0, 0.35));
    text-shadow: 0 1px 8px #000;
  }

  .play-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 999px;
    color: var(--sl-color-accent-high);
    background: rgba(0, 0, 0, 0.72);
    font-size: 1.25rem;
  }

  noscript a {
    color: var(--sl-color-white);
  }

  figcaption {
    margin-block-start: 0.5rem;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-sm);
    line-height: 1.4;
  }
</style>
