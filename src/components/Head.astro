---
import DefaultHead from '@astrojs/starlight/components/Head.astro';
import EventSeo from './EventSeo.astro';

const contentSecurityPolicy = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  "img-src 'self' data: https: https://i.ytimg.com",
  "font-src 'self' data:",
  "style-src 'self' 'unsafe-inline'",
  "script-src 'self' 'unsafe-inline' 'unsafe-eval' https://analytics.mysteryland.biz https://www.youtube.com https://www.youtube-nocookie.com",
  "script-src-elem 'self' 'unsafe-inline' https://analytics.mysteryland.biz https://www.youtube.com https://www.youtube-nocookie.com",
  "frame-src https://www.youtube.com https://www.youtube-nocookie.com",
  "connect-src 'self' ws: wss: http://localhost:* https://analytics.mysteryland.biz",
].join('; ');
---

<meta http-equiv="Content-Security-Policy" content={contentSecurityPolicy} />
<DefaultHead />
<EventSeo />
