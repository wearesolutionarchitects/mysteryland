---
import { Icon } from 'astro-icon/components';
---

<div class="landing-search">
  <button type="button" data-landing-search-open aria-label="Suchen" aria-keyshortcuts="Control+K">
    <Icon name="lucide:search" size="1rem" aria-hidden="true" />
    <span>Suchen</span>
    <kbd><kbd>⌘</kbd><kbd>K</kbd></kbd>
  </button>

  <dialog data-landing-search-dialog aria-label="Suchen">
    <div class="landing-search__dialog">
      <button type="button" data-landing-search-close>Abbrechen</button>
      {import.meta.env.DEV && (
        <p class="landing-search__dev">
          Die Suche nutzt den Pagefind-Index aus dem statischen Build. Im Dev-Server bitte nach `npm run build`
          oder im Preview prüfen.
        </p>
      )}
      <div id="landing__search"></div>
    </div>
  </dialog>
</div>

<script>
  const openButton = document.querySelector<HTMLButtonElement>('[data-landing-search-open]');
  const closeButton = document.querySelector<HTMLButtonElement>('[data-landing-search-close]');
  const dialog = document.querySelector<HTMLDialogElement>('[data-landing-search-dialog]');
  const searchTarget = document.querySelector<HTMLElement>('#landing__search');
  let searchInitialized = false;

  async function initSearch() {
    if (searchInitialized || !searchTarget || import.meta.env.DEV) return;

    // @ts-expect-error Missing package types.
    const { PagefindUI } = await import('@pagefind/default-ui');
    new PagefindUI({
      element: '#landing__search',
      baseUrl: import.meta.env.BASE_URL,
      bundlePath: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/pagefind/`,
      showImages: false,
      showSubResults: true,
      translations: {
        placeholder: 'Suchen',
        clear_search: 'Leeren',
        load_more: 'Mehr laden',
        search_label: 'Diese Website durchsuchen',
        zero_results: 'Keine Ergebnisse für [SEARCH_TERM]',
        one_result: '[COUNT] Ergebnis für [SEARCH_TERM]',
        many_results: '[COUNT] Ergebnisse für [SEARCH_TERM]',
        searching: 'Suche nach [SEARCH_TERM]...',
      },
    });
    searchInitialized = true;
  }

  function openSearch(event?: Event) {
    if (!dialog) return;
    event?.preventDefault();
    dialog.showModal();
    document.body.toggleAttribute('data-search-modal-open', true);
    initSearch().then(() => searchTarget?.querySelector<HTMLInputElement>('input')?.focus());
  }

  function closeSearch() {
    dialog?.close();
  }

  openButton?.addEventListener('click', openSearch);
  closeButton?.addEventListener('click', closeSearch);
  dialog?.addEventListener('close', () => document.body.toggleAttribute('data-search-modal-open', false));
  dialog?.addEventListener('click', (event) => {
    if (event.target === dialog) closeSearch();
  });
  window.addEventListener('keydown', (event) => {
    if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
      dialog?.open ? closeSearch() : openSearch(event);
    }
  });
</script>

<style is:global>
  @import url('@pagefind/default-ui/css/ui.css');

  [data-search-modal-open] {
    overflow: hidden;
  }
</style>

<style>
  .landing-search {
    min-width: min(42rem, 42vw);
  }

  .landing-search button[data-landing-search-open] {
    align-items: center;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    cursor: pointer;
    display: flex;
    font: inherit;
    gap: 0.75rem;
    height: 2.9rem;
    padding: 0 0.9rem;
    text-align: left;
    width: 100%;
  }

  .landing-search button[data-landing-search-open]:hover,
  .landing-search button[data-landing-search-open]:focus-visible {
    border-color: var(--color-red);
    color: var(--sl-color-white);
  }

  .landing-search button[data-landing-search-open] span {
    flex: 1;
  }

  .landing-search kbd {
    align-items: center;
    color: var(--sl-color-gray-2);
    display: inline-flex;
    font: inherit;
    font-size: 0.75rem;
    gap: 0.2rem;
  }

  .landing-search dialog {
    background: var(--sl-color-black);
    border: 1px solid var(--color-red);
    color: var(--sl-color-white);
    margin: 5rem auto auto;
    max-height: calc(100vh - 8rem);
    max-width: 42rem;
    padding: 0;
    width: min(42rem, calc(100vw - 2rem));
  }

  .landing-search dialog::backdrop {
    background: rgb(0 0 0 / 0.72);
    backdrop-filter: blur(0.25rem);
  }

  .landing-search__dialog {
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
  }

  .landing-search [data-landing-search-close] {
    background: transparent;
    border: 0;
    color: var(--color-red);
    cursor: pointer;
    justify-self: end;
  }

  .landing-search__dev {
    border: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    line-height: 1.6;
    margin: 0;
    padding: 1rem;
  }

  #landing__search {
    --pagefind-ui-primary: var(--sl-color-white);
    --pagefind-ui-text: var(--sl-color-gray-2);
    --pagefind-ui-background: var(--sl-color-black);
    --pagefind-ui-border: var(--sl-color-gray-5);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0;
    --pagefind-ui-font: inherit;
    --pagefind-ui-tag: var(--sl-color-gray-5);
  }

  @media (max-width: 58rem) {
    .landing-search {
      min-width: 100%;
      order: 3;
      width: 100%;
    }
  }
</style>
