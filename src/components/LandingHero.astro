---
interface Props {
  counters: Array<{
    displayValue: string;
    format: 'currency' | 'number';
    label: string;
    value: number;
  }>;
  firstYear: number;
  currentYear: number;
}

const { counters, firstYear, currentYear } = Astro.props as Props;
const archiveYears = currentYear - firstYear;
---

<section class="landing-hero" aria-labelledby="landing-title">
  <p class="landing-hero__eyebrow">
    Persönliches Konzertarchiv von <a href="http://www.fanieng.com">Heiko Fanieng</a> seit {firstYear}
  </p>
  <h1 id="landing-title">Mysteryland dokumentiert {archiveYears} Jahre Live-Musik.</h1>
  <p class="landing-hero__intro">
    Tickets, Fotos, Setlists, Tourdaten, Alben und Erinnerungen aus Konzerten, Festivals und Lesungen.
    Das Archiv verbindet persönliche Konzertgeschichte mit strukturierten Daten zu Artists, Venues und Städten.
  </p>
  <div class="landing-hero__actions" aria-label="Schnelleinstiege">
    <a href="/archiv/">Archiv öffnen</a>
    <a href="/events/2026/2026-07-11/">Nächstes Highlight</a>
  </div>
  <dl class="landing-hero__facts" aria-label="Archiv Kennzahlen">
    {counters.map((counter) => (
      <div>
        <dt
          data-counter
          data-counter-format={counter.format}
          data-counter-to={counter.value}
        >
          {counter.displayValue}
        </dt>
        <dd>{counter.label}</dd>
      </div>
    ))}
  </dl>
</section>

<script>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const counters = Array.from(document.querySelectorAll<HTMLElement>('[data-counter]'));
  const numberFormatter = new Intl.NumberFormat('de-DE');
  const currencyFormatter = new Intl.NumberFormat('de-DE', {
    currency: 'EUR',
    maximumFractionDigits: 0,
    style: 'currency',
  });

  const formatCounter = (value: number, format: string | undefined) => {
    if (format === 'currency') return currencyFormatter.format(value);
    return numberFormatter.format(value);
  };

  const animateCounter = (counter: HTMLElement) => {
    const target = Number(counter.dataset.counterTo);
    if (!Number.isFinite(target)) return;

    const format = counter.dataset.counterFormat;
    const duration = 2600;
    const start = performance.now();

    const tick = (now: number) => {
      const progress = Math.min((now - start) / duration, 1);
      const easedProgress = 1 - Math.pow(1 - progress, 3);
      counter.textContent = formatCounter(Math.round(target * easedProgress), format);

      if (progress < 1) window.requestAnimationFrame(tick);
    };

    counter.textContent = formatCounter(0, format);
    window.requestAnimationFrame(tick);
  };

  if (!prefersReducedMotion) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const counter = entry.target;
        if (!(counter instanceof HTMLElement)) return;

        observer.unobserve(counter);
        animateCounter(counter);
      });
    }, { threshold: 0.35 });

    counters.forEach((counter) => observer.observe(counter));
  }
</script>

<style>
  .landing-hero {
    display: grid;
    gap: 1.5rem;
    padding: clamp(1rem, 3vw, 2.5rem) 0 0;
  }

  .landing-hero__eyebrow {
    color: var(--color-red);
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .landing-hero__eyebrow a {
    color: var(--color-red);
    text-decoration: none;
  }

  .landing-hero__eyebrow a:hover,
  .landing-hero__eyebrow a:focus-visible {
    color: var(--sl-color-white);
  }

  .landing-hero h1 {
    color: var(--sl-color-white);
    font-size: clamp(2.5rem, 8vw, 6.5rem);
    letter-spacing: -0.06em;
    line-height: 0.95;
    margin: 0;
    max-width: 11ch;
  }

  .landing-hero__intro {
    color: var(--sl-color-gray-2);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.65;
    margin: 0;
    max-width: 58rem;
  }

  .landing-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .landing-hero__actions a {
    border: 1px solid var(--color-red);
    color: var(--sl-color-white);
    font-weight: 700;
    padding: 0.75rem 1rem;
    text-decoration: none;
  }

  .landing-hero__actions a:hover,
  .landing-hero__actions a:focus-visible {
    background: var(--color-red);
    color: var(--color-black);
  }

  .landing-hero__facts {
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: 1rem 0 0;
  }

  .landing-hero__facts div {
    border-top: 1px solid var(--sl-color-gray-5);
    padding-top: 1rem;
  }

  .landing-hero__facts dt {
    color: var(--sl-color-white);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1;
  }

  .landing-hero__facts dd {
    color: var(--sl-color-gray-2);
    margin: 0.35rem 0 0;
  }

  @media (max-width: 58rem) {
    .landing-hero__facts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 42rem) {
    .landing-hero__facts {
      grid-template-columns: 1fr;
    }
  }
</style>
