---
import { organizersFromTags } from '../data/organizers.mjs';
import {
  googleEventOffer,
  googleEventStatus,
  isoDate,
  isCurrentOrFutureEvent,
} from '../scripts/lib/event-schema.mjs';

const route = Astro.locals.starlightRoute;
const entry = route?.entry;
const data = entry?.data ?? {};
const isEvent = typeof route?.id === 'string' && route.id.startsWith('events/');

function text(value: unknown) {
  const result = String(value || '').trim();
  return result && result !== 'TBA' ? result : '';
}

function values(value: unknown) {
  return [...new Set((Array.isArray(value) ? value : [value])
    .flatMap((item) => String(item || '').split(','))
    .map((item) => item.trim())
    .filter(Boolean)
    .filter((item) => item !== 'TBA'))];
}

function absoluteUrl(value: unknown) {
  const url = String(value || '').trim();
  if (!url) return '';
  if (/^https?:\/\//i.test(url)) return url;

  return new URL(url.startsWith('/') ? url : `/${url}`, Astro.site ?? Astro.url).href;
}

function categoryFromData() {
  const category = text(data.category);
  if (category) return category;

  const tags = values(data.tags).map((tag) => tag.toLocaleLowerCase('de-DE'));
  if (tags.includes('festival')) return 'Festival';
  if (tags.includes('lesung')) return 'Lesung';
  if (tags.includes('konzert')) return 'Konzert';

  return '';
}

function performerType(category: string) {
  return category === 'Lesung' ? 'Person' : 'MusicGroup';
}

function organizerType(category: string) {
  return category === 'Lesung' ? 'Person' : 'Organization';
}

const title = text(data.title);
const description = text(data.description);
const canonical = absoluteUrl(data.canonicalUrl || Astro.url.pathname);
const image = absoluteUrl(data.ogImage || '/apple-touch-icon.png');
const artists = values(data.artist);
const performingAs = text(data.performingAs);
const performers = values([data.artist, data.support, data.guest]);
const startDate = isoDate(data.pubDate);
const endDate = isoDate(data.endDate || data.pubDate);
const price = typeof data.price === 'number' && Number.isFinite(data.price) ? data.price : undefined;
const category = categoryFromData();
const keywords = values(data.tags);
const venue = text(data.venue);
const city = text(data.city);
const country = text(data.country);
const ticketCategory = text(data.ticketCategory);
const explicitOrganizers = values(data.organizer);
const organizers = explicitOrganizers.length ? explicitOrganizers : organizersFromTags(values(data.tags));
const eventId = canonical ? `${canonical}#event` : '';
const eventStatus = googleEventStatus(data.status);
const offer = googleEventOffer({
  price,
  eventStatus,
  startDate,
  url: canonical,
  name: ticketCategory,
});
const isGoogleEvent = isEvent && isCurrentOrFutureEvent(endDate);

// Google event rich results are intended for events people can still attend.
// Archive pages keep their regular metadata, but no longer advertise a past,
// non-bookable event or the unsupported EventCompleted status to Google.
const eventJsonLd = isGoogleEvent ? {
  '@context': 'https://schema.org',
  '@type': 'Event',
  ...(eventId ? { '@id': eventId } : {}),
  name: title,
  ...(performingAs ? { alternateName: performingAs } : {}),
  ...(description ? { description } : {}),
  startDate,
  endDate,
  eventStatus,
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  url: canonical,
  ...(route?.lang ? { inLanguage: route.lang } : {}),
  image: [image],
  ...(category ? { additionalType: category } : {}),
  ...(keywords.length ? { keywords: keywords.join(', ') } : {}),
  location: {
    '@type': 'Place',
    ...(venue ? { name: venue } : {}),
    ...((city || country) ? { address: {
      '@type': 'PostalAddress',
      ...(city ? { addressLocality: city } : {}),
      ...(country ? { addressCountry: country } : {}),
    } } : {}),
  },
  ...(performers.length ? {
    performer: performers.map((name) => ({
      '@type': performerType(category),
      name,
    })),
  } : {}),
  ...(organizers.length ? {
    organizer: organizers.map((name) => ({
      '@type': organizerType(category),
      name,
    })),
  } : {}),
  ...(offer ? { offers: offer } : {}),
} : null;
---

{isEvent && (
  <>
    <meta property="article:published_time" content={startDate} />
    {artists.map((artist) => <meta property="article:tag" content={artist} />)}
    {category && category !== 'TBA' && <meta property="article:section" content={category} />}
    {image && <meta property="og:image" content={image} />}
    {image && <meta name="twitter:image" content={image} />}
    {eventJsonLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
    )}
  </>
)}
