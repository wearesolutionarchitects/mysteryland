---
import { Icon } from 'astro-icon/components';

interface FactLink {
  label: string;
  href?: string;
}

interface Fact {
  icon: string;
  label: string;
  value?: string;
  links?: FactLink[];
}

interface Props {
  facts: Fact[];
}

const { facts } = Astro.props;
const factOrder = new Map([
  ['Land', 10],
  ['Stadt', 20],
  ['Venue', 30],
  ['Datum', 40],
  ['Typ', 50],
  ['Auftritt als', 55],
  ['Tour', 60],
  ['Support', 70],
  ['Preis', 80],
  ['Kategorie', 90],
  ['Veranstalter', 100],
]);

function formatFactValue(label: string, value?: string) {
  if (label !== 'Datum' || !value) return value;

  const match = value.match(/^(\d{2})\.(\d{2})\.(\d{4})$/);
  if (!match) return value;

  return new Intl.DateTimeFormat('de-DE', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  }).format(new Date(`${match[3]}-${match[2]}-${match[1]}T00:00:00Z`));
}

const orderedFacts = facts
  .map((fact, index) => ({
    ...fact,
    value: formatFactValue(fact.label, fact.value),
    index,
  }))
  .sort((a, b) =>
    (factOrder.get(a.label) ?? 1000) - (factOrder.get(b.label) ?? 1000)
    || a.index - b.index
  );
---

<dl class="event-facts">
  {orderedFacts.map(({ icon, label, value, links = [] }) => (
    <div class="event-fact">
      <Icon name={icon} size="1.25rem" aria-hidden="true" />
      <dt>{label}</dt>
      <dd>
        {links.length > 0
          ? links.map(({ label: linkLabel, href }, index) => (
              <>
                {index > 0 && <span>, </span>}
                {href
                  ? <a href={href} target="_blank" rel="noopener noreferrer">{linkLabel}</a>
                  : <span>{linkLabel}</span>}
              </>
            ))
          : value}
      </dd>
    </div>
  ))}
</dl>

<style>
  .event-facts {
    container-type: inline-size;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 11rem), 1fr));
    margin-block: 0 1.5rem;
    padding: 0;
    border: 1px solid var(--color-accent, var(--sl-color-accent-high));
  }

  .event-fact {
    display: grid;
    grid-template-columns: 1.25rem minmax(0, 1fr);
    gap: 0.2rem 0.625rem;
    min-width: 0;
    margin-block-start: 0;
    padding: 1rem;
    border-block-start: 1px solid var(--sl-color-gray-5);
  }

  .event-fact:first-child {
    border-block-start: 0;
  }

  .event-fact :global(svg) {
    flex: 0 0 auto;
    align-self: end;
    color: var(--sl-color-gray-2);
  }

  dt {
    grid-column: 2;
    align-self: end;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    line-height: 1;
  }

  dd {
    grid-column: 1 / -1;
    margin: 0;
    padding-inline-start: 0;
    text-align: left;
    color: var(--sl-color-white);
    font-size: var(--sl-text-sm);
    font-weight: 600;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  dd a {
    color: var(--sl-color-accent-high);
    text-decoration-color: color-mix(in srgb, var(--sl-color-accent-high), transparent 35%);
    text-underline-offset: 0.15em;
  }

  dd a:hover,
  dd a:focus-visible {
    color: var(--sl-color-white);
  }

  :global(.content-panel:has(.event-facts)) {
    padding-top: 0;
  }

  :global(.content-panel:has(+ .content-panel .event-facts)) {
    padding-bottom: 0.75rem;
  }

  @container (min-width: 22rem) {
    .event-fact:nth-child(-n + 2) {
      border-block-start: 0;
    }
  }

  @container (min-width: 33rem) {
    .event-fact:nth-child(-n + 3) {
      border-block-start: 0;
    }
  }

  @container (min-width: 44rem) {
    .event-fact:nth-child(-n + 4) {
      border-block-start: 0;
    }
  }

  @container (min-width: 55rem) {
    .event-fact:nth-child(-n + 5) {
      border-block-start: 0;
    }
  }
</style>
