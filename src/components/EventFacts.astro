---
import { Icon } from 'astro-icon/components';

interface FactLink {
  label: string;
  href?: string;
}

interface Fact {
  icon: string;
  label: string;
  value?: string;
  links?: FactLink[];
}

interface Props {
  facts: Fact[];
}

const { facts } = Astro.props;
---

<dl class="event-facts">
  {facts.map(({ icon, label, value, links = [] }) => (
    <div class="event-fact">
      <Icon name={icon} size="1.25rem" aria-hidden="true" />
      <dt>{label}</dt>
      <dd>
        {links.length > 0
          ? links.map(({ label: linkLabel, href }, index) => (
              <>
                {index > 0 && <span>, </span>}
                {href
                  ? <a href={href} target="_blank" rel="noopener noreferrer">{linkLabel}</a>
                  : <span>{linkLabel}</span>}
              </>
            ))
          : value}
      </dd>
    </div>
  ))}
</dl>

<style>
  .event-facts {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem 1.5rem;
    margin-block: 0 1.5rem;
    padding-block: 1rem;
    border-block: 1px solid var(--sl-color-gray-5);
  }

  .event-fact {
    display: grid;
    grid-template-columns: 1.25rem minmax(0, 1fr);
    gap: 0.2rem 0.625rem;
    min-width: 0;
    margin-block-start: 0;
  }

  .event-fact :global(svg) {
    flex: 0 0 auto;
    align-self: end;
    color: var(--sl-color-gray-2);
  }

  dt {
    grid-column: 2;
    align-self: end;
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-xs);
    font-weight: 600;
    line-height: 1;
  }

  dd {
    grid-column: 1 / -1;
    margin: 0;
    padding-inline-start: 0;
    text-align: left;
    color: var(--sl-color-white);
    font-size: var(--sl-text-sm);
    font-weight: 600;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }

  dd a {
    color: var(--sl-color-accent-high);
    text-decoration-color: color-mix(in srgb, var(--sl-color-accent-high), transparent 35%);
    text-underline-offset: 0.15em;
  }

  dd a:hover,
  dd a:focus-visible {
    color: var(--sl-color-white);
  }

  :global(.content-panel:has(.event-facts)) {
    padding-top: 0;
  }

  :global(.content-panel:has(+ .content-panel .event-facts)) {
    padding-bottom: 0.75rem;
  }

  @media (min-width: 22rem) {
    .event-facts {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 42rem) {
    .event-facts {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
