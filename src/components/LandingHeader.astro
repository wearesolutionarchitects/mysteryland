type BrandIcon = keyof typeof brandIcons;

const socials: Array<{ icon: BrandIcon; label: string; href: string }> = [
  { icon: 'github', label: 'GitHub', href: 'https://github.com/wearesolutionarchitects' },
  { icon: 'discord', label: 'Discord', href: 'https://discord.gg/GEdQ3xg6t6' },
  { icon: 'linkedin', label: 'LinkedIn', href: 'https://www.linkedin.com/in/hfanieng/' },
  { icon: 'twitch', label: 'Twitch', href: 'https://www.twitch.tv/mysteryland1909' },
  { icon: 'youtube', label: 'YouTube', href: 'http://www.youtube.com/@mysterylanddotbiz' },
  { icon: 'instagram', label: 'Instagram', href: 'https://www.instagram.com/heikofanieng/' },
  { icon: 'facebook', label: 'Facebook', href: 'https://www.facebook.com/Mysteryland1909' },
];
---

<header class="landing-header">
  <div class="landing-header__inner">
    <a class="landing-header__logo" href="/" aria-label="Mysteryland Startseite">
      <Image src={logo} alt="" width={214} height={80} />
      <span>Mysteryland</span>
    </a>

    <LandingSearch />

    <div class="landing-header__right">
      <nav class="landing-header__socials" aria-label="Social Media">
        {socials.map((social) => (
          <a href={social.href} rel="me" aria-label={social.label}>
            <svg aria-hidden="true" viewBox="0 0 24 24" set:html={brandIcons[social.icon]} />
          </a>
        ))}
      </nav>
      <label class="landing-theme">
        <span class="sr-only">Farbschema wählen</span>
        <Icon name="lucide:moon" size="1rem" aria-hidden="true" />
        <select data-landing-theme-select autocomplete="off">
          <option value="dark" selected>Dunkel</option>
          <option value="light">Hell</option>
        </select>
        <Icon name="lucide:chevron-down" size="1rem" aria-hidden="true" />
      </label>
    </div>
  </div>
</header>

<script>
  const themeSelect = document.querySelector<HTMLSelectElement>('[data-landing-theme-select]');
  const storedTheme = localStorage.getItem('starlight-theme');
  const initialTheme = storedTheme === 'light' ? 'light' : 'dark';

  document.documentElement.dataset.theme = initialTheme;
  if (themeSelect) themeSelect.value = initialTheme;

  themeSelect?.addEventListener('change', (event) => {
    const target = event.currentTarget;
    if (!(target instanceof HTMLSelectElement)) return;

    const value = target.value === 'light' ? 'light' : 'dark';
    document.documentElement.dataset.theme = value;
    localStorage.setItem('starlight-theme', value);
  });
</script>

<style>
  .landing-header {
    background: var(--sl-color-black);
    display: grid;
    grid-template-columns: minmax(9rem, 14rem) minmax(0, 74rem) max-content;
    gap: 1rem;
    min-height: 4rem;
    padding: 0.75rem clamp(1rem, 4vw, 3rem);
  }

  .landing-header__inner {
    align-items: center;
    background: var(--sl-color-black);
    display: contents;
  }

  :global(.landing-search) {
    justify-self: start;
  }

  @media (min-width: 86rem) {
    :global(.landing-search) {
      margin-left: clamp(1rem, 4vw, 3rem);
    }
  }

  @media (max-width: 58rem) {
    .landing-header {
      grid-template-columns: 1fr auto;
    }

    :global(.landing-search) {
      grid-column: 1 / -1;
      margin-left: 0;
      width: 100%;
    }
  }

  .landing-header__logo {
    align-items: center;
    display: inline-flex;
    text-decoration: none;
  }

  .landing-header__logo img {
    display: block;
    height: auto;
    width: clamp(9rem, 12vw, 13.5rem);
  }

  .landing-header__logo span {
    clip: rect(0 0 0 0);
    border: 0;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .landing-header__right {
    align-items: center;
    display: flex;
    gap: 1rem;
    justify-content: end;
    min-width: 0;
  }

  .landing-header__socials {
    align-items: center;
    display: flex;
    gap: 0.75rem;
  }

  .landing-header__socials a {
    color: var(--sl-color-accent);
    display: inline-flex;
  }

  .landing-header__socials svg {
    color: var(--sl-color-accent);
    fill: var(--sl-color-accent);
    height: 1rem;
    width: 1rem;
  }

  .landing-header__socials a:hover,
  .landing-header__socials a:focus-visible {
    color: var(--sl-color-white);
  }

  .landing-theme {
    align-items: center;
    border-left: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-2);
    display: flex;
    gap: 0.35rem;
    padding-left: 1rem;
  }

  .landing-theme select {
    appearance: none;
    background: transparent;
    border: 0;
    color: inherit;
    font: inherit;
  }

  .sr-only {
    clip: rect(0 0 0 0);
    border: 0;
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  @media (max-width: 58rem) {
    .landing-header__right {
      justify-content: end;
    }

    .landing-header__socials {
      display: none;
    }
  }
</style>
