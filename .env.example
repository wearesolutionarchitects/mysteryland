# Copy this file to .env and adjust values for your setup.

# Generic repository used by GitHub CLI scripts
REPO=wearesolutionarchitects/mysteryland

# WordPress source settings
WP_BASE_URL=https://fanieng.com
WP_CATEGORY_ID=1
WP_PER_PAGE=100

# setlist.fm API key (required for script:external:setlist)
SETLIST_API_KEY=

# iCloud photo sync settings
ICLOUD_USERNAME=heiko@fanieng.com
ICLOUD_DIRECTORY=/Volumes/Sandisk/Fotos
ICLOUD_RECENT_DAYS=5
