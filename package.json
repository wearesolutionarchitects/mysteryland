{
  "name": "mysteryland",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=26",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=ExperimentalWarning astro dev",
    "build": "NODE_OPTIONS=--disable-warning=ExperimentalWarning astro build",
    "preview": "NODE_OPTIONS=--disable-warning=ExperimentalWarning astro preview",
    "astro": "NODE_OPTIONS=--disable-warning=ExperimentalWarning astro",
    "check": "astro check",
    "typecheck:ts": "tsc --noEmit",
    "verify": "npm run check && npm run typecheck:ts && npm run build",
    "deploy:ssh": "node scripts/deploy/ssh-deploy-astro.mjs",
    "postinstall": "patch-package",
    "event:wp": "node src/scripts/event/wp.mjs",
    "event:setlist": "node src/scripts/event/setlist.mjs",
    "event:media": "node src/scripts/event/media.mjs",
    "event:mdx": "node src/scripts/event/mdx.mjs",
    "event:og": "node src/scripts/event/og.mjs",
    "event:seo": "node src/scripts/event/seo.mjs",
    "event:outbox": "node src/scripts/event/outbox.mjs",
    "event:album": "node src/scripts/event/album.mjs",
    "event:covers": "node src/scripts/event/localize-album-covers.mjs",
    "artist:sync": "node src/scripts/artist/sync.mjs",
    "script:content:generate-readme": "node src/scripts/content/generate-readme.mjs",
    "script:github:create-labels": "node src/scripts/github/create-label.mjs"
  },
  "dependencies": {
    "@astrojs/preact": "^6.0.1",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.1",
    "@iconify-json/lucide": "^1.2.111",
    "astro": "^7.0.3",
    "astro-icon": "^1.1.5",
    "glightbox": "^3.3.1",
    "preact": "^10.29.7",
    "sharp": "^0.34.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.1.1",
    "patch-package": "^8.0.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}
